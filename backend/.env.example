# LLM Provider: "bedrock", "groq", "google", "openai", or "cerebras"
LLM_PROVIDER=groq

# Fallback chain
FALLBACK_PROVIDERS=groq,google,cerebras

# API Keys
GROQ_API_KEY=
GOOGLE_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=

# AWS Bedrock (optional — for local dev with SSO)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL=apac.amazon.nova-lite-v1:0

# Models
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o
CEREBRAS_MODEL=llama3.1-8b

# Embeddings: "local" for dev (needs RAM), "google" for production (free API)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
